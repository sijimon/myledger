# Copy to .env and fill in. NEVER commit the real .env.

# --- Database ---
DB_NAME=myledger
DB_USER=myledger
DB_PASSWORD=change-me-strong-db-password

# --- Auth ---
# Any long random string; it is hashed to a 256-bit HMAC key.
JWT_SECRET=change-me-to-a-long-random-secret

# One-time owner seed (created only if it does not already exist).
OWNER_EMAIL=owner@myledger.local
OWNER_PASSWORD=change-me-owner-password

# Set true once served over HTTPS (Cloudflare Tunnel) so the refresh cookie is Secure.
COOKIE_SECURE=false

# Leave empty in production (SPA served same-origin via nginx). For running the Vite
# dev server directly against the backend, set to http://localhost:5173.
CORS_ORIGINS=

# Host port the web frontend is published on (target for Cloudflare Tunnel).
WEB_PORT=8088
